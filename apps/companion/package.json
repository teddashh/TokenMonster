{
  "name": "@tokenmonster/companion",
  "productName": "TokenMonster",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main/main/main.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit && vite build --config vite.main.config.ts && vite build --config vite.preload.config.ts && vite build --config vite.preload-index.config.ts && vite build --config vite.companion-preload.config.ts && vite build --config vite.config.ts && node ../../scripts/verify-companion-bundles.mjs",
    "dev": "vite",
    "make:internal": "node ../../scripts/package-companion.mjs make internal",
    "make:signed": "node ../../scripts/package-companion.mjs make signed",
    "package:internal": "node ../../scripts/package-companion.mjs package internal",
    "start": "electron .",
    "test": "vite build --config vite.main.config.ts && vite build --config vite.preload.config.ts && vite build --config vite.preload-index.config.ts && vite build --config vite.companion-preload.config.ts && node ../../scripts/verify-companion-bundles.mjs && vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@tokenmonster/byok-openai": "0.1.0",
    "@tokenmonster/characters": "0.1.0",
    "@tokenmonster/collector-core": "0.1.0",
    "@tokenmonster/companion-gateway": "0.1.0",
    "@tokenmonster/companion-ui": "0.1.0",
    "@tokenmonster/contribution-runtime": "0.1.0",
    "@tokenmonster/contracts": "0.1.0",
    "@tokenmonster/local-store": "0.1.0",
    "@tokenmonster/monster-engine": "0.1.0",
    "@tokenmonster/secret-vault": "0.1.0",
    "@tokenmonster/token-tracker-adapter": "0.1.0",
    "@tokenmonster/token-tracker-runtime": "0.1.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@electron/asar": "4.2.0",
    "@electron/fuses": "1.8.0",
    "@electron/osx-sign": "1.3.3",
    "@electron/packager": "18.4.4",
    "@electron/windows-sign": "1.2.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "cross-zip": "4.0.1",
    "electron": "43.1.1",
    "electron-installer-dmg": "5.0.1",
    "electron-winstaller": "5.4.4",
    "vite": "8.1.4",
    "yauzl": "2.10.0"
  }
}
