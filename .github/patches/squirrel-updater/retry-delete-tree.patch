         public static async Task DeleteDirectoryOrJustGiveUp(string dir)
         {
-            try {
-                await Utility.DeleteDirectory(dir);
-            } catch {
-                var message = String.Format("Uninstall failed to delete dir '{0}'", dir);
+            const int attempts = 32;
+            const int delayMilliseconds = 250;
+
+            for (var attempt = 0; attempt < attempts; attempt++) {
+                try {
+                    await Utility.DeleteDirectory(dir);
+                } catch {
+                    // Preserve this helper's existing best-effort behavior.
+                }
+
+                // DeleteDirectory logs and swallows Directory.Delete failures, so
+                // existence is the only reliable signal that a retry is needed.
+                if (!Directory.Exists(dir)) return;
+
+                if (attempt + 1 < attempts) {
+                    await Task.Delay(delayMilliseconds);
+                }
             }
         }
 
