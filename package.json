{
  "name": "tokenmonster-workspace",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": "24.15.0",
    "npm": "11.12.1"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "miniflare": {
      "sharp": "0.35.3"
    }
  },
  "scripts": {
    "agent:audit": "node scripts/agent/audit.mjs",
    "agent:doctor": "node scripts/agent/doctor.mjs",
    "agent:launch": "node scripts/agent/launch.mjs",
    "agent:status": "node scripts/agent/status.mjs",
    "agent:stop": "node scripts/agent/stop.mjs",
    "agent:verify": "node --test --test-concurrency=1 scripts/agent/tests/*.test.mjs",
    "audit:zstd-native-prebuild": "node scripts/release/audit-zstd-native-prebuild.mjs --all",
    "build": "node scripts/run-workspaces.mjs build",
    "format:check": "node scripts/verify-format.mjs",
    "lint": "node scripts/verify-repository.mjs",
    "make:companion:internal": "npm run make:internal --workspace @tokenmonster/companion",
    "make:companion:signed": "npm run make:signed --workspace @tokenmonster/companion",
    "package:companion:internal": "npm run package:internal --workspace @tokenmonster/companion",
    "prepare:asset-release-slots": "node scripts/asset-pipeline/prepare-release-slots.mjs",
    "test": "npm run agent:verify && node scripts/run-workspaces.mjs test",
    "typecheck": "node scripts/run-workspaces.mjs typecheck && tsc -p tsconfig.release-scripts.json",
    "verify:artifacts": "node scripts/verify-release-artifacts.mjs",
    "verify:companion-package": "node scripts/verify-companion-package.mjs --mode internal",
    "verify:packaging-toolchain": "node scripts/verify-packaging-toolchain.mjs",
    "verify:secrets": "node scripts/scan-secrets.mjs",
    "verify:zstd-native-prebuild": "node scripts/release/zstd-native-verifier.mjs --installed-root ."
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
