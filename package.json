{
  "name": "tokenmonster-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": "24.15.0",
    "npm": "11.12.1"
  },
  "overrides": {
    "@electron-forge/cli@7.11.2": {
      "@electron/rebuild": "4.2.0",
      "tmp": "0.2.7"
    }
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "node scripts/run-workspaces.mjs build",
    "format:check": "node scripts/verify-format.mjs",
    "lint": "node scripts/verify-repository.mjs",
    "make:companion:internal": "npm run make:internal --workspace @tokenmonster/companion",
    "make:companion:signed": "npm run make:signed --workspace @tokenmonster/companion",
    "package:companion:internal": "npm run package:internal --workspace @tokenmonster/companion",
    "test": "node scripts/run-workspaces.mjs test",
    "typecheck": "node scripts/run-workspaces.mjs typecheck",
    "verify:artifacts": "node scripts/verify-release-artifacts.mjs",
    "verify:companion-package": "node scripts/verify-companion-package.mjs --mode internal",
    "verify:packaging-toolchain": "node scripts/verify-packaging-toolchain.mjs",
    "verify:secrets": "node scripts/scan-secrets.mjs"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
